{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "job-scout-intake",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-14",
  "keep_vars": true,
  "vars": {
    "OPENAI_BRIEF_MODEL": "gpt-5.4-nano",
    "BRIEF_ENRICH_LIMIT": "4"
  },
  "secrets": {
    "required": ["NOTION_TOKEN", "SESSION_SECRET", "OPENAI_API_KEY"]
  }
}
